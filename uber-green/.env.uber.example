# ── Uber Guest Rides API ──────────────────────────────────────────────────────
# Register at https://developer.uber.com → Create Application
# Enable scope: guests.trips
# Contact your Uber BD rep to unlock production access

UBER_CLIENT_ID=your_client_id_here
UBER_CLIENT_SECRET=your_client_secret_here

# true = sandbox (default), false = production
UBER_SANDBOX=true

# Sandbox run UUID — required for sandbox estimate calls.
# Obtain by running:  python -m uber_green.sandbox_setup
# Then copy the printed run ID here.
UBER_SANDBOX_RUN_UUID=

# Uber for Business organisation UUID (required for 3P/B2B apps)
# Found in your Uber for Business dashboard
UBER_ORG_UUID=

# Nairobi Uber Green product ID.
# Discover by running:  python -m uber_green.sandbox_setup
# then copy the product_id printed for the Green product.
UBER_GREEN_PRODUCT_ID=

# Optional: Open Exchange Rates app ID for live USD/KES conversion
# Free tier: https://openexchangerates.org/signup/free
OPENEXCHANGERATES_APP_ID=

# Fallback KES rate (used when OXR is not configured)
USD_TO_KES=130.0
