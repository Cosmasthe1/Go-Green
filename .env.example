# ══════════════════════════════════════════════════════════════════════════════
# Go Green — Master Environment Variables
# Copy this file to .env in the relevant sub-project folder and fill in values.
# Never commit .env files to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── Anthropic (backend + mcp-app) ─────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ── Safaricom Daraja / M-Pesa (backend) ───────────────────────────────────────
MPESA_SANDBOX=true
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
MPESA_CALLBACK_URL=https://your-domain.com/api/mpesa/callback

# ── WhatsApp (backend) ────────────────────────────────────────────────────────
WA_PROVIDER=twilio                        # twilio | meta
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
META_ACCESS_TOKEN=your_meta_token
META_PHONE_NUMBER_ID=your_phone_id
META_VERIFY_TOKEN=gogreen_verify_2025

# ── Backend server ports ──────────────────────────────────────────────────────
PORT=7860
CARBON_PORT=7861

# ── Uber Green (uber-green/) ──────────────────────────────────────────────────
UBER_CLIENT_ID=your_uber_client_id
UBER_CLIENT_SECRET=your_uber_client_secret
UBER_SANDBOX=true
UBER_SANDBOX_RUN_UUID=
UBER_ORG_UUID=
UBER_GREEN_PRODUCT_ID=
USD_TO_KES=130.0
OPENEXCHANGERATES_APP_ID=

# ── Verra Registry (verra-registry/) ─────────────────────────────────────────
VCS_PROJECT_ID=
VCS_PROJECT_NAME=Go Green EV Fleet Kenya
VCS_PROJECT_COUNTRY=Kenya
VCS_PROPONENT_NAME=Go Green Limited
VCS_PROPONENT_EMAIL=registry@gogreen.co.ke
VCS_ACCOUNT_NUMBER=
VVB_NAME=
VVB_ACCREDITATION=
MIN_VCU_THRESHOLD=50.0
MIN_TRIPS=100
MAX_PERIOD_DAYS=90
GOGREEN_DB_PATH=gogreen_carbon.db
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=registry@gogreen.co.ke
SMTP_PASSWORD=your_app_password
SMTP_FROM=Go Green Registry <registry@gogreen.co.ke>
VERRA_REGISTRY_EMAIL=registry@verra.org
GOGREEN_CC_EMAIL=team@gogreen.co.ke

# ── Mobile App (mobile-app/) ──────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:5000
VITE_WS_URL=ws://localhost:5000/ws
