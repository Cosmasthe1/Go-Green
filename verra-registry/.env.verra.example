# ── Verra VCS Project ────────────────────────────────────────────────────────
# Obtain after completing VCS project registration at registry.verra.org
VCS_PROJECT_ID=                        # e.g. 3456  (assigned by Verra)
VCS_PROJECT_NAME=Go Green EV Fleet Kenya
VCS_PROJECT_COUNTRY=Kenya
VCS_PROPONENT_NAME=Go Green Limited
VCS_PROPONENT_EMAIL=registry@gogreen.co.ke
VCS_ACCOUNT_NUMBER=                    # Your Verra registry account number

# ── VVB (Validation and Verification Body) ────────────────────────────────────
# Accredited under ISO 14065. Required before VCU issuance.
# List of accredited VVBs: https://verra.org/programs/verified-carbon-standard/vvbs/
VVB_NAME=                              # e.g. SustainCERT, Bureau Veritas, DNV
VVB_ACCREDITATION=                     # e.g. ISO 14065:2020

# ── Issuance queue thresholds ────────────────────────────────────────────────
# Batch is promoted to READY when ANY of these is met:
MIN_VCU_THRESHOLD=50.0                 # minimum tCO2e before submitting
MIN_TRIPS=100                          # minimum trips before submitting
MAX_PERIOD_DAYS=90                     # force submission after 90 days (quarterly)

# ── SQLite database path ──────────────────────────────────────────────────────
GOGREEN_DB_PATH=gogreen_carbon.db

# ── SMTP (for email submission to registry@verra.org) ────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=registry@gogreen.co.ke
SMTP_PASSWORD=your_app_password_here   # Use app password, not account password
SMTP_FROM=Go Green Registry <registry@gogreen.co.ke>
VERRA_REGISTRY_EMAIL=registry@verra.org
GOGREEN_CC_EMAIL=team@gogreen.co.ke

# ── Open Exchange Rates (optional, for live USD→KES rate) ────────────────────
OPENEXCHANGERATES_APP_ID=              # https://openexchangerates.org/signup/free
USD_TO_KES=130.0                       # fallback rate
